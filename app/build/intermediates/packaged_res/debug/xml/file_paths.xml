<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- 应用外部文件目录 - 用于相机拍照 -->
    <external-files-path
        name="my_images"
        path="Pictures" />
    
    <!-- 应用外部缓存目录 -->
    <external-cache-path
        name="my_cache"
        path="." />
    
    <!-- 应用内部文件目录 -->
    <files-path
        name="internal_files"
        path="." />
    
    <!-- 应用内部缓存目录 -->
    <cache-path
        name="internal_cache"
        path="." />
    
    <!-- 外部存储根目录（谨慎使用） -->
    <external-path
        name="external_files"
        path="." />
    
    <!-- 下载目录 -->
    <external-path
        name="downloads"
        path="Download/" />
    
</paths>
